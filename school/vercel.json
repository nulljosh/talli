{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["data/**"] }
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/web/.*\\.(css|js|svg|png|jpg|ico)$",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    { "src": "/api/(.*)", "dest": "/src/server.js" },
    { "src": "^/$", "dest": "/web/school.html" },
    { "src": "/(.*\\.(html|css|js|json|png|jpg|svg|ico))", "dest": "/web/$1" }
  ]
}
